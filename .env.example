# ==============================================================================
# BuzzNa D74 Environment Configuration
# ==============================================================================
# Copy this file to .env and populate with actual values

# Application
NODE_ENV=development
PORT=3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/buzzna_db

# Redis (for caching and BullMQ background jobs)
REDIS_URL=redis://:password@host:6379/0

# JWT Secrets (minimum 32 characters, use: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_access_secret_here_minimum_32_characters_required
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_32_characters_required

# Paystack Integration
# Test mode: sk_test_...
# Live mode: sk_live_...
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key_here
PAYSTACK_WEBHOOK_HMAC_SECRET=your_webhook_hmac_secret_here
PAYSTACK_MODE=test

# Safaricom Daraja M-Pesa Integration
DARASA_GLOBAL_TIMEOUT_MS=30000
MPESA_SENDER_SMS_WHITELIST=MPESA,M-PESA,254722000000

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info
